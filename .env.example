# Neon PostgreSQL connection string (provided by Vercel integration)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js - generate with: openssl rand -hex 32
AUTH_SECRET=

# Resend email delivery - get from https://resend.com/api-keys
AUTH_RESEND_KEY=

# Optional: email "from" address (requires verified domain in Resend)
# EMAIL_FROM=noreply@yourdomain.com
